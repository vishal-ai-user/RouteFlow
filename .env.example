# =============================================================================
# RouteFlow Environment Variables
# See ENVIRONMENT_REFERENCE.md for full documentation.
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Core ---
# ROUTEFLOW_AUTH_TOKEN=your-secret-gateway-token
ROUTEFLOW_HOST=0.0.0.0
ROUTEFLOW_PORT=8000
ROUTEFLOW_LOG_LEVEL=INFO
ROUTEFLOW_DATABASE_PATH=routeflow.db
# ROUTEFLOW_ENCRYPTION_KEY=your-encryption-key

# --- Model ---
ROUTEFLOW_DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Runtime ---
ROUTEFLOW_SCHEDULER_MODE=health-first
ROUTEFLOW_RETRY_COUNT=2
ROUTEFLOW_TIMEOUT_SECONDS=60
ROUTEFLOW_STREAMING_ENABLED=true
ROUTEFLOW_THINKING_ENABLED=true
ROUTEFLOW_MAX_REQUEST_SIZE_MB=10

# --- Provider Bootstrap (development only) ---
# Prefer database-backed config for production.
# ROUTEFLOW_NVIDIA_1_API_KEY=nvapi-xxx
# ROUTEFLOW_NVIDIA_1_LABEL=account-1
# ROUTEFLOW_NVIDIA_2_API_KEY=nvapi-xxx
# ROUTEFLOW_NVIDIA_2_LABEL=account-2

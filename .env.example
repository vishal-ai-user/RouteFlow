# =============================================================================
# AEGIS Environment Variables
# See ENVIRONMENT_REFERENCE.md for full documentation.
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Core ---
# AEGIS_AUTH_TOKEN=your-secret-gateway-token
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_LOG_LEVEL=INFO
AEGIS_DATABASE_PATH=aegis.db
# AEGIS_ENCRYPTION_KEY=your-encryption-key

# --- Model ---
AEGIS_DEFAULT_MODEL=claude-sonnet-4-20250514

# --- Runtime ---
AEGIS_SCHEDULER_MODE=health-first
AEGIS_RETRY_COUNT=2
AEGIS_TIMEOUT_SECONDS=60
AEGIS_STREAMING_ENABLED=true
AEGIS_THINKING_ENABLED=true
AEGIS_MAX_REQUEST_SIZE_MB=10

# --- Provider Bootstrap (development only) ---
# Prefer database-backed config for production.
# AEGIS_NVIDIA_1_API_KEY=nvapi-xxx
# AEGIS_NVIDIA_1_LABEL=account-1
# AEGIS_NVIDIA_2_API_KEY=nvapi-xxx
# AEGIS_NVIDIA_2_LABEL=account-2
